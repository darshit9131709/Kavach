# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kavach
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/kavach

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# Application Configuration
NODE_ENV=development

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# External APIs (if needed)
# API_KEY=your-api-key-here

# Arya Chatbot (external AI forwarder)
# This project forwards chat requests to your AI provider endpoint.
# Do NOT put secrets in client-side code.
ARYA_AI_ENDPOINT_URL=https://example.com/ai/chat
# Optional (only if your provider needs it)
ARYA_AI_API_KEY=

# Vapi Web Voice Integration
NEXT_PUBLIC_VAPI_PUBLIC_KEY=bbac49c2-3f5b-4f18-aa06-72240db5c4cb
NEXT_PUBLIC_VAPI_ASSISTANT_ID=your-vapi-assistant-id
VAPI_PRIVATE_API_KEY=your-vapi-private-api-key
