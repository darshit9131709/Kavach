# MongoDB Configuration
MONGODB_URI=mongodb://localhost:27017/kavach
# For MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/kavach

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here-change-in-production

# JWT Configuration
JWT_SECRET=your-jwt-secret-key-here-change-in-production

# Application Configuration
NODE_ENV=development

# Email Configuration (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# External APIs (if needed)
# API_KEY=your-api-key-here

# SOS alerts use WhatsApp deep links (no API key needed)

# AI Backend URL (gesture detection for dashcam)
AI_BACKEND_URL=http://127.0.0.1:5000/detect

